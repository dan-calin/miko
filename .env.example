# Copy this file to ".env" and fill in your own values. Never commit the real .env.

# ── Core LLM (Google Gemini Live) ───────────────────────────────────────────
LLM_API_KEY=                 # Google Gemini API key — https://aistudio.google.com/apikey
LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
MIKO_VOICE=Aoede
OWNER_NAME=Your Name
MIKO_LANGUAGE=en             # "en" (English) or "ro" (Romanian) — default user-facing language

# ── Discord bot (optional) ──────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=
TRUSTED_VOICE_USERS=         # comma-separated Discord usernames allowed to issue voice commands

# ── MiniMax (optional — used by the phone commander) ────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# ── Phone / iCloud (optional) ───────────────────────────────────────────────
PHONE_MODEL=
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=         # app-specific password, NOT your Apple ID password

# ── Azure / Microsoft Teams calendar (optional) ─────────────────────────────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=common       # use "common" for a personal-account app registration

# ── Personal Discord account control via local RPC (optional) ───────────────
# Controls YOUR own Discord desktop client (join voice as you, mute yourself).
# You own the app, so the restricted `rpc` scopes work without whitelist approval.
DISCORD_RPC_CLIENT_ID=
DISCORD_RPC_CLIENT_SECRET=
DISCORD_RPC_REDIRECT=http://localhost   # must match a redirect URI on your app

# ── Tool server (HTTP bridge for external agents) ───────────────────────────
TOOL_SERVER_PORT=7832
TOOL_SERVER_KEY=             # bearer token required by the /tools endpoints

# ── Maps / location (optional) ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
HOME_POSTCODE=
