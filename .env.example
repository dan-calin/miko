# Copy this file to ".env" and fill in your own values. Never commit the real .env.

# ── Core LLM / transcription fallback ───────────────────────────────────────
LLM_API_KEY=                 # Google Gemini API key — https://aistudio.google.com/apikey
LIVE_MODEL=models/gemini-3.1-flash-live-preview   # only used when MIKO_VOICE_ENGINE=live
MIKO_VOICE=Aoede
OWNER_NAME=Your Name
MIKO_LANGUAGE=en             # "en" (English) or "ro" (Romanian) — default user-facing language

# ── Voice engine (main.py) ───────────────────────────────────────────────────
MIKO_VOICE_ENGINE=chat       # "chat" (default: STT → chat brain → TTS; steadier, ~3-10s)
                             #  or "live" (Gemini Live realtime — lowest latency, preview API)
MIKO_VOICE_PROVIDER=         # chat-engine brain: openrouter / nvidia / minimax / gemini / openai / … (default:
                             #  minimax if MINIMAX_API_KEY is set, else gemini)
MIKO_VOICE_MODEL=            # optional model override for the voice brain
MIKO_VOICE_FALLBACK_PROVIDER=gemini  # retry voice turns here after provider rate/quota limits; set "off" to disable
MIKO_VOICE_FALLBACK_MODEL=   # optional fallback model override (default provider model)
MIKO_VOICE_FALLBACK_BASE_URL= # optional fallback local/OpenAI-compatible URL
MIKO_VOICE_FALLBACK_API_KEY= # optional fallback provider key override
MIKO_VOICE_BASE_URL=         # optional: local OpenAI-compatible URL, e.g. http://127.0.0.1:1234/v1
MIKO_VOICE_API_KEY=          # optional: local server key, e.g. lm-studio
MIKO_VOICE_COMPACT_TOOLS=true  # compact tool list for local/small-context voice models
MIKO_VOICE_INTERRUPT=true    # allow TTS playback to be interrupted
MIKO_VOICE_INTERRUPT_MODE=speech  # "speech" = natural barge-in, "phrase" = stop phrases only
MIKO_VOICE_INTERRUPT_SENSITIVITY=medium  # high/medium/low; lower if fans/speakers false-trigger
# MIKO_VOICE_INTERRUPT_MIN_MS=240  # optional override: sustained speech before barge-in fires
# MIKO_VOICE_INTERRUPT_THRESHOLD_MULTIPLIER=1.35  # optional override: barge-in volume strictness
MIKO_VOICE_MAX_UTTER_SECS=90  # max single STT clip before chunking a very long spoken prompt
MIKO_VOICE_TURN_GRACE_SECS=0.8  # pause window used to merge follow-on chunks before Miko answers
MIKO_VOICE_INCOMPLETE_GRACE_SECS=3.0  # extra wait after unfinished endings like "regarding" / "legate de"
MIKO_VAD_END_SILENCE_MS=900    # silence before one audio chunk ends; raise if prompts still cut off
MIKO_TTS_VOICE=              # edge-tts voice (default en-US-JennyNeural / ro-RO-AlinaNeural)
MIKO_VAD_THRESHOLD=350       # mic speech-detection floor (raise in noisy rooms)
MIKO_VOICE_ALLOW_ACTIONS=true  # voice commands may run sensitive actions (you're the owner)

# Sub-agent model selection
MIKO_SUBAGENT_MODEL_MODE=main  # "main" = inherit current chat/voice model; "custom" = fields below
MIKO_SUBAGENT_PROVIDER=        # custom mode: gemini / openrouter / nvidia / openai / minimax / custom / ...
MIKO_SUBAGENT_MODEL=           # custom mode model, e.g. openrouter/free
MIKO_SUBAGENT_BASE_URL=        # custom mode base URL, only needed for custom/OpenAI-compatible endpoints
MIKO_SUBAGENT_API_KEY=         # optional custom key override; blank uses the provider key above

# ── Discord bot (optional) ──────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=
TRUSTED_VOICE_USERS=         # comma-separated Discord usernames allowed to issue voice commands

# ── MiniMax (optional — used by the phone commander) ────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M3

# ── Chat UI providers (optional — keys can also be entered in the UI) ────────
# The web Chat UI (http://localhost:7832/chat) can use any of these.
OPENAI_API_KEY=
OPENROUTER_API_KEY=          # OpenRouter API key for models like openrouter/free
NVIDIA_API_KEY=              # NVIDIA NIM key for z-ai/glm-5.2 / google/diffusiongemma-26b-a4b-it
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=            # Kimi / Moonshot

# ── Phone / iCloud (optional) ───────────────────────────────────────────────
PHONE_MODEL=
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=         # app-specific password, NOT your Apple ID password

# ── Azure / Microsoft Teams calendar (optional) ─────────────────────────────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=common       # use "common" for a personal-account app registration

# ── Personal Discord account control via local RPC (optional) ───────────────
# Controls YOUR own Discord desktop client (join voice as you, mute yourself).
# You own the app, so the restricted `rpc` scopes work without whitelist approval.
DISCORD_RPC_CLIENT_ID=
DISCORD_RPC_CLIENT_SECRET=
DISCORD_RPC_REDIRECT=http://localhost   # must match a redirect URI on your app

# ── Tool server (HTTP bridge for external agents) ───────────────────────────
TOOL_SERVER_PORT=7832
TOOL_SERVER_HOST=            # default 127.0.0.1 (loopback only). To expose on the
                             # network set e.g. 0.0.0.0 — requires TOOL_SERVER_KEY,
                             # otherwise Miko falls back to loopback.
TOOL_SERVER_KEY=             # bearer token required by the /tools endpoints

# ── Maps / location (optional) ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
HOME_POSTCODE=

# ── Email (optional — IMAP read/triage + SMTP send + inbox watch) ───────────
# Gmail: enable 2FA, then create an App Password (Google Account → Security →
# App passwords) and use it as EMAIL_PASS. Hosts below already match Gmail.
EMAIL_USER=                  # email address / username
EMAIL_PASS=                  # password or app-specific password (Gmail: App Password)
EMAIL_IMAP_HOST=             # e.g. imap.gmail.com
EMAIL_IMAP_PORT=993          # SSL
EMAIL_SMTP_HOST=             # e.g. smtp.gmail.com
EMAIL_SMTP_PORT=587          # 587 STARTTLS, or 465 SSL
EMAIL_FROM=                  # optional display From (defaults to EMAIL_USER)
MIKO_EMAIL_WATCH_INTERVAL=30  # inbox-watch poll seconds (min 15); used by "ping me when X emails"

# ── Voice dictation (chat UI mic) ───────────────────────────────────────────
# Web Speech transcribes one language at a time. Set a BCP-47 tag to force it
# (e.g. ro-RO or en-US). If unset, it follows MIKO_LANGUAGE (en→en-US, ro→ro-RO).
MIKO_DICTATION_LANG=
# Fallback transcription model (browsers without Web Speech, e.g. Firefox).
MIKO_DICTATION_MODEL=gemini-2.5-flash-lite

# ── Extra chat providers (optional) ─────────────────────────────────────────
ANTHROPIC_API_KEY=           # real Claude (claude-opus-4-8, …)
XAI_API_KEY=                 # xAI Grok
