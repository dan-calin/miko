# Copy this file to ".env" and fill in your own values. Never commit the real .env.

# ── Core LLM (Google Gemini Live) ───────────────────────────────────────────
LLM_API_KEY=                 # Google Gemini API key — https://aistudio.google.com/apikey
LIVE_MODEL=models/gemini-3.1-flash-live-preview   # Gemini 3 Flash Live (was 2.5 native-audio)
MIKO_VOICE=Aoede
OWNER_NAME=Your Name
MIKO_LANGUAGE=en             # "en" (English) or "ro" (Romanian) — default user-facing language

# ── Discord bot (optional) ──────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_GUILD_ID=
TRUSTED_VOICE_USERS=         # comma-separated Discord usernames allowed to issue voice commands

# ── MiniMax (optional — used by the phone commander) ────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# ── Chat UI providers (optional — keys can also be entered in the UI) ────────
# The web Chat UI (http://localhost:7832/chat) can use any of these.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=            # Kimi / Moonshot

# ── Phone / iCloud (optional) ───────────────────────────────────────────────
PHONE_MODEL=
ICLOUD_EMAIL=
ICLOUD_APP_PASSWORD=         # app-specific password, NOT your Apple ID password

# ── Azure / Microsoft Teams calendar (optional) ─────────────────────────────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=common       # use "common" for a personal-account app registration

# ── Personal Discord account control via local RPC (optional) ───────────────
# Controls YOUR own Discord desktop client (join voice as you, mute yourself).
# You own the app, so the restricted `rpc` scopes work without whitelist approval.
DISCORD_RPC_CLIENT_ID=
DISCORD_RPC_CLIENT_SECRET=
DISCORD_RPC_REDIRECT=http://localhost   # must match a redirect URI on your app

# ── Tool server (HTTP bridge for external agents) ───────────────────────────
TOOL_SERVER_PORT=7832
TOOL_SERVER_KEY=             # bearer token required by the /tools endpoints

# ── Maps / location (optional) ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
HOME_POSTCODE=

# ── Email (optional — IMAP read/triage + SMTP send + inbox watch) ───────────
# Gmail: enable 2FA, then create an App Password (Google Account → Security →
# App passwords) and use it as EMAIL_PASS. Hosts below already match Gmail.
EMAIL_USER=                  # email address / username
EMAIL_PASS=                  # password or app-specific password (Gmail: App Password)
EMAIL_IMAP_HOST=             # e.g. imap.gmail.com
EMAIL_IMAP_PORT=993          # SSL
EMAIL_SMTP_HOST=             # e.g. smtp.gmail.com
EMAIL_SMTP_PORT=587          # 587 STARTTLS, or 465 SSL
EMAIL_FROM=                  # optional display From (defaults to EMAIL_USER)
MIKO_EMAIL_WATCH_INTERVAL=30  # inbox-watch poll seconds (min 15); used by "ping me when X emails"

# ── Voice dictation (chat UI mic) ───────────────────────────────────────────
# Web Speech transcribes one language at a time. Set a BCP-47 tag to force it
# (e.g. ro-RO or en-US). If unset, it follows MIKO_LANGUAGE (en→en-US, ro→ro-RO).
MIKO_DICTATION_LANG=
# Fallback transcription model (browsers without Web Speech, e.g. Firefox).
MIKO_DICTATION_MODEL=gemini-2.5-flash

# ── Extra chat providers (optional) ─────────────────────────────────────────
ANTHROPIC_API_KEY=           # real Claude (claude-opus-4-8, …)
XAI_API_KEY=                 # xAI Grok
